enum Prefix {
  Mr
  Mrs
  Miss
}

enum JobLevel {
  S1
  S2
  M1
  M2
}

enum EmployeeStatus {
  Active
  Resigned
}

model Employee {
  id          String         @id @default(cuid())
  employeeNo  String         @unique              @map("employee_no")
  prefix      Prefix
  firstName   String                              @map("first_name")
  lastName    String                              @map("last_name")
  idCardNo    String?        @unique @db.Char(13) @map("id_card_no")
  hireDate    DateTime?      @db.Date             @map("hire_date")
  jobLevel    JobLevel                            @map("job_level")
  status      EmployeeStatus @default(Active)
  createdAt   DateTime       @default(now())      @map("created_at")
  updatedAt   DateTime       @updatedAt           @map("updated_at")

  // Relations
  user         User?

  plantId      String           @map("plant_id")
  plant        Plant            @relation(fields: [plantId], references: [id])

  buId         String           @map("bu_id")
  businessUnit BusinessUnit     @relation(fields: [buId], references: [id])

  functionId   String           @map("function_id")
  orgFunction  OrgFunction      @relation(fields: [functionId], references: [id])

  divisionId   String           @map("division_id")
  division     Division         @relation(fields: [divisionId], references: [id])

  departmentId String           @map("department_id")
  department   Department       @relation(fields: [departmentId], references: [id])

  trainingRecords TrainingRecord[]

  @@index([plantId])
  @@index([buId])
  @@index([functionId])
  @@index([divisionId])
  @@index([departmentId])
  @@map("employees")
}

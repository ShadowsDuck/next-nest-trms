enum Prefix {
  Mr
  Mrs
  Miss
}

enum JobLevel {
  S1
  S2
  M1
  M2
}

enum EmployeeStatus {
  Active
  Resigned
}

model Employee {
  id          String         @id @default(cuid())
  employeeNo  String         @unique              @map("employee_no")
  prefix      Prefix
  firstName   String                              @map("first_name")
  lastName    String                              @map("last_name")
  idCardNo    String?        @unique @db.Char(13) @map("id_card_no")
  hireDate    DateTime?      @db.Date             @map("hire_date")
  jobLevel    JobLevel                            @map("job_level")
  status      EmployeeStatus @default(Active)
  createdAt   DateTime       @default(now())      @map("created_at")
  updatedAt   DateTime       @updatedAt           @map("updated_at")

  // Relations
  user         User?

  orgUnitId    String?          @map("org_unit_id")
  orgUnit      OrganizationUnit? @relation(fields: [orgUnitId], references: [id])

  trainingRecords TrainingRecord[]
  
  @@map("employees")
}

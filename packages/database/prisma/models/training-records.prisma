model TrainingRecord {
  id               String   @id @default(cuid())
  certFilePath     String?  @map("cert_file_path")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  employeeId       String   @map("employee_id")
  employee         Employee @relation(fields: [employeeId], references: [id])

  courseId         String   @map("course_id")
  course           Course   @relation(fields: [courseId], references: [id])

  createdByUserId  String   @map("created_by_user_id")
  createdByUser    User     @relation("TrainingRecordCreatedBy", fields: [createdByUserId], references: [id])

  updatedByUserId  String   @map("updated_by_user_id")
  updatedByUser    User     @relation("TrainingRecordUpdatedBy", fields: [updatedByUserId], references: [id])

  @@unique([employeeId, courseId], name: "uq_training_record")
  @@index([employeeId])
  @@index([courseId])
  @@map("training_records")
}
model Plant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  businessUnits BusinessUnit[]
  employees     Employee[]

  @@map("plants")
}

model BusinessUnit {
  id        String   @id @default(cuid())
  name      String
  plantId   String   @map("plant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  plant         Plant          @relation(fields: [plantId], references: [id])
  orgFunctions  OrgFunction[]
  employees     Employee[]

  @@unique([plantId, name])
  @@index([plantId])
  @@map("business_units")
}

model OrgFunction {
  id             String   @id @default(cuid())
  name           String
  businessUnitId String   @map("business_unit_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  businessUnit BusinessUnit @relation(fields: [businessUnitId], references: [id])
  divisions    Division[]
  employees    Employee[]

  @@unique([businessUnitId, name])
  @@index([businessUnitId])
  @@map("org_functions")
}

model Division {
  id         String   @id @default(cuid())
  name       String
  functionId String   @map("function_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  orgFunction  OrgFunction  @relation(fields: [functionId], references: [id])
  departments  Department[]
  employees    Employee[]

  @@unique([functionId, name])
  @@index([functionId])
  @@map("divisions")
}

model Department {
  id         String   @id @default(cuid())
  name       String
  divisionId String   @map("division_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  division   Division   @relation(fields: [divisionId], references: [id])
  employees  Employee[]

  @@unique([divisionId, name])
  @@index([divisionId])
  @@map("departments")
}

# PORT
PORT= # Example: 8000

# DATABASE
DATABASE_URL= # Example: postgresql://user:password@host:port/database

# BETTER_AUTH
ALLOWED_ORIGINS= # Example: http://localhost:3000, Your frontend URL
BETTER_AUTH_URL= # Example: http://localhost:8000, Your backend URL

BETTER_AUTH_SECRET= # Example: your-secret-key

# GOOGLE
GOOGLE_CLIENT_ID= # Example: your-google-client-id
GOOGLE_CLIENT_SECRET= # Example: your-google-client-secret

# ONEDRIVE (Personal Mode - Central Account)
ONEDRIVE_CLIENT_ID= # Microsoft App (Personal account capable)
ONEDRIVE_CLIENT_SECRET= # Microsoft App secret
ONEDRIVE_REFRESH_TOKEN= # Refresh token of the central uploader account
ONEDRIVE_FOLDER_ID= # Target folder id in central OneDrive
ONEDRIVE_SCOPE=offline_access Files.ReadWrite # Keep this for personal mode
ONEDRIVE_TOKEN_ENDPOINT=https://login.microsoftonline.com/consumers/oauth2/v2.0/token

# ONEDRIVE (Microsoft 365 Organization Migration Notes)
# 1) Keep same env keys and same upload code path.
# 2) Replace ONEDRIVE_TOKEN_ENDPOINT with tenant/org endpoint:
#    https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
# 3) Replace ONEDRIVE_REFRESH_TOKEN with token issued from org account consent.
# 4) Keep ONEDRIVE_FOLDER_ID as folder id in org OneDrive/SharePoint drive.
